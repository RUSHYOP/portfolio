# MongoDB connection string (Railway)
MONGODB_URI=mongodb://username:password@host.railway.app:port/database

# Admin credentials (REQUIRED — app will not start without these)
ADMIN_EMAIL=your_email@example.com
ADMIN_PASSWORD=your_secure_password_here

# JWT secret for admin sessions (REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=generate_64_char_hex_string_here

# Seed API secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SEED_SECRET_KEY=generate_64_char_hex_string_here
